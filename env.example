# -------------------------------------------------------
# Copy this file to .env and fill in your values
# Never commit .env to GitHub
# -------------------------------------------------------

# --- AI Provider (choose ONE, comment out the others) ---

# OPTION 1: Groq (FREE - recommended)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# OPTION 2: OpenAI (PAID - requires billing)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# OPTION 3: Anthropic (PAID - $5 free credits on signup)
# Get your key at: https://console.anthropic.com
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Email ---
# The email address where you want to receive your daily briefing
EMAIL_RECIPIENT=you@gmail.com
